model: Qwen3.5-35B-A3B-GPTQ-Int4
api_key: apy_key
base_url: http://192.168.10.151:8000/v1
api_mode: chat

final_evaluation:
  enabled: true
  max_retries: 3

tools:
  rag:
    enabled: true
  web_search:
    enabled: false
  sandbox:
    enabled: true
    image: maigent-sandbox:py311
    timeout_seconds: 300
    install_libraries_on_run: false
    allowed_libraries:
      - beautifulsoup4
      - charset-normalizer
      - lxml
      - matplotlib
      - numpy
      - openpyxl
      - pandas
      - pdfplumber
      - pillow
      - pypdf
      - python-docx
      - python-pptx
      - reportlab
      - requests
      - scipy
      - seaborn
      - tabulate
      - xlsxwriter
      - xlrd
